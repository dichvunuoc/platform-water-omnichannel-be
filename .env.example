# Service Configuration
PORT=3000
NODE_ENV=development
SERVICE_NAME=nestjs-ddd-api
SERVICE_VERSION=1.0.0

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestjs_project
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nestjs_project

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Observability
LOG_LEVEL=debug
JAEGER_ENDPOINT=http://localhost:14268/api/traces
PROMETHEUS_PORT=9464

# Security
JWT_SECRET=super-secret-key-change-me-in-production
RATE_LIMIT_REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-32-chars-min-secret-value
# Origins of frontend clients served from a different origin/port (comma-separated).
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001

# Zalo OAuth (social login)
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_REDIRECT_URI=http://localhost:3000/api/auth/zalo/callback

# Zalo OA Omnichannel (inbound webhook + Account Linking).
# Set ZALO_OA_ENABLED=true + fill credentials from a registered Zalo Official Account to go live.
# ZALOA_SECRET_KEY  = OA webhook secret used to HMAC-verify inbound payloads.
# ZALO_OA_*         = OA credentials for outbound messaging + token refresh.
ZALO_OA_ENABLED=false
ZALOA_SECRET_KEY=
ZALO_OA_ID=
ZALO_OA_APP_ID=
ZALO_OA_APP_SECRET=
ZALO_OA_REFRESH_TOKEN=
ZALO_OA_BASE_URL=https://openapi.zaloapp.com
